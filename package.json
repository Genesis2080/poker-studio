{
  "name": "poker-tracker",
  "version": "1.0.0",
  "description": "Poker hand tracker — Electron + React",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "dist": "vite build && electron-builder",
    "dist:win": "vite build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.pokertracker.app",
    "productName": "Poker Tracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "dir"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "vite": "^5.4.2",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "sql.js": "^1.12.0"
  }
}
